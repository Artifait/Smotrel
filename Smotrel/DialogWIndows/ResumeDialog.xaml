<Window x:Class="Smotrel.DialogWindows.ResumeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Продолжить просмотр"
        Width="420" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Border Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="12">
        <StackPanel Margin="28,24,28,24">

            <!-- Заголовок -->
            <TextBlock Text="Продолжить просмотр?"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="Courier New" FontSize="28"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <!-- Название видео -->
            <TextBlock x:Name="TbVideoTitle"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontFamily="Arial" FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center" Margin="0,0,0,8"
                       HorizontalAlignment="Center"/>

            <!-- Кнопки выбора -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Продолжить с позиции -->
                <Border x:Name="BtnResume"
                        Grid.Column="0"
                        CornerRadius="8"
                        Padding="12,14"
                        Cursor="Hand"
                        MouseLeftButtonDown="BtnResume_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Style.Triggers>
                                <!-- Выделение при фокусе (навигация клавишами) -->
                                <DataTrigger Binding="{Binding IsResumeSelected}"
                                             Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Background"  Value="{StaticResource AccentGlowBrush}"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE768;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="22"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Продолжить с"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Arial" FontSize="11"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TbResumeTime"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Начать сначала -->
                <Border x:Name="BtnRestart"
                        Grid.Column="2"
                        CornerRadius="8"
                        Padding="12,14"
                        Cursor="Hand"
                        MouseLeftButtonDown="BtnRestart_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"    Value="{StaticResource CardBackgroundBrush}"/>
                            <Setter Property="BorderBrush"   Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsResumeSelected}"
                                             Value="False">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Background"  Value="{StaticResource AccentGlowBrush}"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72C;" FontStretch="Expanded"
                                   FontFamily="Segoe MDL2 Assets" FontSize="22"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Начать сначала"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Arial" FontSize="11"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="с начала"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Подсказка -->
            <TextBlock Text="← → для выбора  ·  Enter для подтверждения"
                       Foreground="{StaticResource EmptyMessageBrush}"
                       FontFamily="Arial" FontSize="10"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0"/>
        </StackPanel>
    </Border>
</Window>