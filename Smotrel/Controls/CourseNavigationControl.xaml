<!-- Controls/CourseNavigationControl.xaml — только визуальные изменения,
     code-behind остаётся прежним                                         -->
<UserControl x:Class="Smotrel.Controls.CourseNavigationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Smotrel.ViewModels"
             Background="{StaticResource StatsPanelBackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Кнопка-иконка (прозрачная) -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Focusable"       Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ── Inline-редактор ────────────────────────────── -->
        <Style x:Key="InlineEd" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource CardHoverBrush}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding"         Value="2,2"/>
            <Setter Property="CaretBrush"      Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource AccentGlowBrush}"/>
            <Setter Property="FontFamily"      Value="Arial"/>
        </Style>

        <!-- ── Заголовок секции (ГЛАВЫ / ВИДЕО) ──────────── -->
        <Style x:Key="SecHdr" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource EmptyMessageBrush}"/>
            <Setter Property="FontFamily"  Value="Arial"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>

        <!-- ── DataTemplate: карточка ГЛАВЫ ──────────────── -->
        <DataTemplate DataType="{x:Type vm:ChapterCardVm}">
            <Border BorderThickness="1" CornerRadius="6"
                    Margin="0,0,0,3" Padding="10,8"
                    Cursor="Hand"
                    MouseLeftButtonDown="ChapterCard_MouseDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderNormalBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding Label}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Arial" FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsNotEditing,
                                  Converter={StaticResource BoolVis}}"/>

                    <TextBox Grid.Column="0"
                             Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InlineEd}" FontSize="13"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolVis}}"
                             IsVisibleChanged="Editor_IsVisibleChanged"
                             LostFocus="ChapterCardEditor_LostFocus"
                             KeyDown="ChapterCardEditor_KeyDown"/>

                    <!-- Стрелка навигации -->
                    <TextBlock Grid.Column="1"
                               Text="&#xE76C;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="10"
                               Foreground="{StaticResource EmptyMessageBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               Visibility="{Binding IsNotEditing,
                                  Converter={StaticResource BoolVis}}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ── DataTemplate: карточка ВИДЕО ──────────────── -->
        <DataTemplate DataType="{x:Type vm:VideoCardVm}">
            <Border BorderThickness="1" CornerRadius="6"
                    Margin="0,0,0,3" Padding="8,7"
                    Cursor="Hand"
                    MouseLeftButtonDown="VideoCard_MouseDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderNormalBrush}"/>
                            </Trigger>
                            <!-- Текущее видео: красная рамка слева + чуть другой фон -->
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter Property="BorderBrush"  Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Background"   Value="{StaticResource AccentGlowBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                    </Grid.ColumnDefinitions>

                    <!-- IsWatched кнопка -->
                    <Button Grid.Column="0"
                            Width="20" Height="20" Padding="1"
                            VerticalAlignment="Center"
                            ToolTip="Отметить просмотренным"
                            Style="{StaticResource SettingsBtn}"
                            Click="VideoWatchedBtn_Click">
                        <TextBlock Text="{Binding WatchedGlyph}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="11" VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{Binding WatchedColorHex}"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Button>

                    <!-- Название / редактор -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   FontFamily="Arial" FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding IsNotEditing,
                                      Converter={StaticResource BoolVis}}"
                                   MouseLeftButtonDown="VideoTitle_MouseDown">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource TextPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InlineEd}" FontSize="12"
                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolVis}}"
                                 IsVisibleChanged="Editor_IsVisibleChanged"
                                 LostFocus="VideoCardEditor_LostFocus"
                                 KeyDown="VideoCardEditor_KeyDown"/>
                    </Grid>

                    <!-- Маркер текущего (F0D6) -->
                    <TextBlock Grid.Column="2"
                               Text="&#xF0D6;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12" Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Visibility="{Binding IsCurrent, Converter={StaticResource BoolVis}}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ── DataTemplate: таймкод ──────────────────────── -->
        <DataTemplate DataType="{x:Type vm:TimecodeVm}">
            <Border CornerRadius="4" Margin="0,0,0,2" Padding="8,5"
                    Cursor="Hand"
                    MouseLeftButtonDown="TimecodeRow_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"
                                        Value="{StaticResource CardBackgroundBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding TimeText}"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Consolas" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding Label}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Arial" FontSize="16"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="2"
                            Width="16" Height="16" Padding="0"
                            Style="{StaticResource IconBtn}"
                            ToolTip="Удалить метку"
                            Click="DeleteTimecode_Click">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="9" Foreground="{StaticResource EmptyMessageBrush}"/>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- ═══ БЛОК 1: НАВИГАЦИЯ ════════════════════════ -->
            <Border BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,12,12,14">
                <StackPanel>

                    <!-- Шапка: кнопка вверх + название главы -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnUp"
                                Grid.Column="0"
                                Width="28" Height="28" Padding="4"
                                Margin="0,0,8,0"
                                Visibility="Collapsed"
                                ToolTip="К родительской главе"
                                Style="{StaticResource IconBtn}"
                                Click="BtnUp_Click">
                            <TextBlock Text="&#xE72B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>

                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TbChapterName"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Arial" FontSize="14" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                       MouseLeftButtonDown="ChapterName_MouseDown"/>

                            <TextBox x:Name="EdChapterName"
                                     Style="{StaticResource InlineEd}"
                                     FontSize="14" FontWeight="SemiBold"
                                     Visibility="Collapsed"
                                     IsVisibleChanged="Editor_IsVisibleChanged"
                                     LostFocus="ChapterHeaderEditor_LostFocus"
                                     KeyDown="ChapterHeaderEditor_KeyDown"/>
                        </Grid>
                    </Grid>

                    <!-- Подглавы -->
                    <StackPanel x:Name="SecChapters" Visibility="Collapsed">
                        <TextBlock Text="ГЛАВЫ" Style="{StaticResource SecHdr}"/>
                        <ItemsControl x:Name="IcChapters" Margin="0,0,0,4"/>
                    </StackPanel>

                    <!-- Видео -->
                    <StackPanel x:Name="SecVideos" Visibility="Collapsed">
                        <TextBlock Text="ВИДЕО" Style="{StaticResource SecHdr}"/>
                        <ItemsControl x:Name="IcVideos"/>
                    </StackPanel>

                    <!-- Пусто -->
                    <TextBlock x:Name="TbEmpty"
                               Text="Эта глава пуста"
                               Foreground="{StaticResource EmptyMessageBrush}"
                               FontFamily="Arial" FontSize="12" FontStyle="Italic"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- ═══ БЛОК 2: ИНФОРМАЦИЯ О ВИДЕО ══════════════ -->
            <Border BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,12,12,14">
                <StackPanel>
                    <TextBlock Text="ТЕКУЩЕЕ ВИДЕО" Style="{StaticResource SecHdr}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="TbVideoTitle"
                               Text="—"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Arial" FontSize="16" FontWeight="SemiBold"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Просмотрено"
                                   Foreground="{StaticResource EmptyMessageBrush}"
                                   FontFamily="Arial" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TbWatchPct"
                                   Grid.Column="1" Text="0%"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Arial" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <ProgressBar x:Name="PbWatch"
                                 Height="4" Minimum="0" Maximum="100" Value="0"
                                 Margin="0,0,0,12"/>

                    <!-- Кнопка добавить метку -->
                    <Border x:Name="BtnAddTimecode"
                            CornerRadius="6"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Margin="0,0,0,8"
                            Cursor="Hand"
                            MouseLeftButtonDown="AddTimecode_MouseDown">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush"
                                                Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="Background"
                                                Value="{StaticResource CardHoverBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,7">
                            <TextBlock Text="&#xF8AA;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource EmptyMessageBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Добавить метку"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Arial" FontSize="14"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl x:Name="IcTimecodes"/>

                    <TextBlock x:Name="TbNoTimecodes"
                               Text="Меток нет"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Arial" FontSize="15" FontStyle="Italic"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- ═══ БЛОК 3: ПРОГРЕСС ГЛАВЫ ══════════════════ -->
            <Border Padding="12,12,12,18">
                <StackPanel>
                    <TextBlock Text="ПРОГРЕСС ГЛАВЫ" HorizontalAlignment="Center" FontSize="14" Style="{StaticResource SecHdr}" Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <TextBlock x:Name="TbChapterPct"
                               Text="0%"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Rockwell" FontSize="36" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,2"/>

                    <TextBlock x:Name="TbChapterRatio"
                               Text="0 / 0 видео завершено"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Arial" FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <ProgressBar x:Name="PbChapter"
                                 Height="5" Minimum="0" Maximum="100" Value="0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>