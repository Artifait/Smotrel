<UserControl x:Class="Smotrel.Controls.CourseNavigationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Smotrel.ViewModels"
             Background="{StaticResource StatsPanelBackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Кнопка-иконка (прозрачная) -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Focusable"       Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inline-редактор -->
        <Style x:Key="InlineEd" TargetType="TextBox">
            <Setter Property="Background"      Value="#252525"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#FF0033"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Setter Property="CaretBrush"      Value="White"/>
            <Setter Property="SelectionBrush"  Value="#44FF0033"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Заголовок секции -->
        <Style x:Key="SecHdr" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource PrimaryForegroundBrush}"/>
            <Setter Property="FontFamily"  Value="Arial"/>
            <Setter Property="FontSize"    Value="20"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>

        <!-- ══════════════════════════════════════════════════════
             DataTemplate: карточка ГЛАВЫ  (ChapterCardVm)
        ══════════════════════════════════════════════════════ -->
        <DataTemplate DataType="{x:Type vm:ChapterCardVm}">
            <Border x:Name="Bd"
                    Background="{StaticResource ButtonDarkBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Margin="0,0,0,4" Padding="10,8"
                    Cursor="Hand"
                    MouseLeftButtonDown="ChapterCard_MouseDown">

                <!-- Hover -->
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource ButtonDarkBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <!-- Читаемое название -->
                    <TextBlock Text="{Binding Label}"
                               Foreground="White" FontFamily="Arial" FontSize="13"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                               Visibility="{Binding IsNotEditing, Converter={StaticResource BoolVis}}"/>

                    <!-- Inline-редактор -->
                    <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InlineEd}" FontSize="13"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolVis}}"
                             IsVisibleChanged="Editor_IsVisibleChanged"
                             LostFocus="ChapterCardEditor_LostFocus"
                             KeyDown="ChapterCardEditor_KeyDown"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ══════════════════════════════════════════════════════
             DataTemplate: карточка ВИДЕО  (VideoCardVm)
        ══════════════════════════════════════════════════════ -->
        <DataTemplate DataType="{x:Type vm:VideoCardVm}">
            <Border x:Name="Bd"
                    BorderThickness="1" CornerRadius="6"
                    Margin="0,0,0,4" Padding="8,7"
                    Cursor="Hand"
                    MouseLeftButtonDown="VideoCard_MouseDown">

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background"   Value="{StaticResource ButtonDarkBrush}"/>
                        <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <!-- Текущее видео: красная рамка + тёмно-красный фон -->
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter Property="BorderBrush" Value="#55FF0033"/>
                                <Setter Property="Background"  Value="#180A0A"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                    </Grid.ColumnDefinitions>

                    <!-- Кнопка IsWatched -->
                    <Button Grid.Column="0"
                            Width="22" Height="22" Padding="2"
                            VerticalAlignment="Center"
                            ToolTip="Отметить просмотренным"
                            Style="{StaticResource IconBtn}"
                            Click="VideoWatchedBtn_Click">
                        <TextBlock Text="{Binding WatchedGlyph}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{Binding WatchedColorHex}"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <!-- Название / редактор -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White" FontFamily="Arial" FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding IsNotEditing, Converter={StaticResource BoolVis}}"
                                   MouseLeftButtonDown="VideoTitle_MouseDown"/>

                        <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InlineEd}" FontSize="12"
                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolVis}}"
                                 IsVisibleChanged="Editor_IsVisibleChanged"
                                 LostFocus="VideoCardEditor_LostFocus"
                                 KeyDown="VideoCardEditor_KeyDown"/>
                    </Grid>

                    <!-- Маркер текущего (F0D6) -->
                    <TextBlock Grid.Column="2"
                               Text="&#xF0D6;" FontFamily="Segoe MDL2 Assets"
                               FontSize="12" Foreground="#FF0033"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Visibility="{Binding IsCurrent, Converter={StaticResource BoolVis}}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ══════════════════════════════════════════════════════
             DataTemplate: строка ТАЙМКОДА  (TimecodeVm)
        ══════════════════════════════════════════════════════ -->
        <DataTemplate DataType="{x:Type vm:TimecodeVm}">
            <Border CornerRadius="4" Margin="0,0,0,3" Padding="8,5"
                    Cursor="Hand"
                    MouseLeftButtonDown="TimecodeRow_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource ButtonDarkBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding TimeText}"
                               Foreground="#FF0033" FontFamily="Arial"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="2"
                               Text="{Binding Label}"
                               Foreground="{StaticResource LightGrayBrush}"
                               FontFamily="Arial" FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="3"
                            Width="16" Height="16" Padding="0"
                            Style="{StaticResource IconBtn}"
                            ToolTip="Удалить метку"
                            Click="DeleteTimecode_Click">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="9" Foreground="#555555"/>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <!-- ════════════════════════════════════════════════════════════
         ROOT LAYOUT
    ════════════════════════════════════════════════════════════════ -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- ═══ БЛОК 1: НАВИГАЦИЯ ════════════════════════════════ -->
            <Border BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="10,10,10,12">
                <StackPanel>

                    <!-- ── Шапка: кнопка вверх + название главы ────── -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Кнопка "к родителю" -->
                        <Button x:Name="BtnUp"
                                Grid.Column="0"
                                Width="30" Height="30" Padding="4"
                                Margin="0,0,8,0"
                                Visibility="Collapsed"
                                ToolTip="К родительской главе"
                                Style="{StaticResource IconBtn}"
                                Click="BtnUp_Click">
                            <TextBlock Text="&#xE72B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Foreground="White"/>
                        </Button>

                        <!-- Название главы / редактор шапки -->
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TbChapterName"
                                       Foreground="White" FontFamily="Arial"
                                       FontSize="14" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       MouseLeftButtonDown="ChapterName_MouseDown"/>

                            <TextBox x:Name="EdChapterName"
                                     Style="{StaticResource InlineEd}"
                                     FontSize="14" FontWeight="SemiBold"
                                     Visibility="Collapsed"
                                     IsVisibleChanged="Editor_IsVisibleChanged"
                                     LostFocus="ChapterHeaderEditor_LostFocus"
                                     KeyDown="ChapterHeaderEditor_KeyDown"/>
                        </Grid>
                    </Grid>

                    <!-- ── Подглавы ──────────────────────────────────── -->
                    <StackPanel x:Name="SecChapters" Visibility="Collapsed">
                        <TextBlock Text="ГЛАВЫ" Style="{StaticResource SecHdr}"/>
                        <ItemsControl x:Name="IcChapters" Margin="0,0,0,6"/>
                    </StackPanel>

                    <!-- ── Видео ─────────────────────────────────────── -->
                    <StackPanel x:Name="SecVideos" Visibility="Collapsed">
                        <ItemsControl x:Name="IcVideos"/>
                    </StackPanel>

                    <!-- Пусто -->
                    <TextBlock x:Name="TbEmpty"
                               Text="Эта глава пуста"
                               Foreground="{StaticResource EmptyMessageBrush}"
                               FontFamily="Arial" FontSize="12" FontStyle="Italic"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- ═══ БЛОК 2: ИНФОРМАЦИЯ О ВИДЕО ══════════════════════ -->
            <Border BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="10,12,10,12">
                <StackPanel>
                    <TextBlock Text="ТЕКУЩЕЕ ВИДЕО" Style="{StaticResource SecHdr}"
                               Margin="0,0,0,10"/>

                    <!-- Название -->
                    <TextBlock x:Name="TbVideoTitle"
                               Text="—"
                               Foreground="White" FontFamily="Arial"
                               FontSize="13" FontWeight="SemiBold"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <!-- Процент + цвет -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Просмотрено"
                                   Foreground="{StaticResource LightGrayBrush}"
                                   FontFamily="Arial" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TbWatchPct"
                                   Grid.Column="1" Text="0%"
                                   FontFamily="Arial" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource LightGrayBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <ProgressBar x:Name="PbWatch"
                                 Height="5" Minimum="0" Maximum="100"
                                 Value="0"
                                 Foreground="#FF0033"
                                 Background="{StaticResource ButtonDarkBrush}"
                                 BorderThickness="0"
                                 Margin="0,0,0,14"/>

                    <!-- Кнопка добавить метку -->
                    <Border x:Name="BtnAddTimecode"
                            CornerRadius="5"
                            Background="{StaticResource ButtonDarkBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Margin="0,0,0,10"
                            Cursor="Hand"
                            MouseLeftButtonDown="AddTimecode_MouseDown">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#FF0033"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="+ Добавить метку"
                                   Foreground="{StaticResource LightGrayBrush}"
                                   FontFamily="Arial" FontSize="12"
                                   HorizontalAlignment="Center"
                                   Padding="0,8"/>
                    </Border>

                    <!-- Список таймкодов -->
                    <ItemsControl x:Name="IcTimecodes"/>

                    <TextBlock x:Name="TbNoTimecodes"
                               Text="Меток нет"
                               Foreground="{StaticResource PrimaryForegroundBrush}"
                               FontFamily="Arial" FontSize="19" FontStyle="Italic"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- ═══ БЛОК 3: ПРОГРЕСС ГЛАВЫ ══════════════════════════ -->
            <Border Padding="10,12,10,18">
                <StackPanel>
                    <TextBlock Text="ПРОГРЕСС ГЛАВЫ" Style="{StaticResource SecHdr}"
                               Margin="0,0,0,10" HorizontalAlignment="Center"/>

                    <TextBlock x:Name="TbChapterPct"
                               Text="0%"
                               Foreground="White" FontFamily="Rockwell"
                               FontSize="38" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,2"/>

                    <TextBlock x:Name="TbChapterRatio"
                               Text="0 / 0 видео завершено"
                               Foreground="{StaticResource PrimaryForegroundBrush}"
                               FontFamily="Arial" FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <ProgressBar x:Name="PbChapter"
                                 Height="6" Minimum="0" Maximum="100"
                                 Value="0"
                                 Foreground="#FF0033"
                                 Background="{StaticResource ButtonDarkBrush}"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
