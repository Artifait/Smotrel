<!-- Themes/Colors.xaml — полная замена -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════
         ОСНОВНАЯ ПАЛИТРА  (вдохновлена Discord Dark)
    ══════════════════════════════════════════════════════ -->

    <!-- Слои фона — от самого тёмного к светлее -->
    <Color x:Key="BgDeep"      >#0F1011</Color>  <!-- под рамкой окна          -->
    <Color x:Key="BgBase"      >#1A1B1E</Color>  <!-- фон главного окна        -->
    <Color x:Key="BgElevated"  >#1E2024</Color>  <!-- заголовок, шапки секций  -->
    <Color x:Key="BgPanel"     >#25272C</Color>  <!-- сайдбар, панели          -->
    <Color x:Key="BgCard"      >#2B2D32</Color>  <!-- карточки, поля ввода     -->
    <Color x:Key="BgCardHover" >#32353B</Color>  <!-- карточка при наведении   -->
    <Color x:Key="BgCardActive">#393C43</Color>  <!-- карточка нажата/активна  -->

    <!-- Границы -->
    <Color x:Key="BorderSubtle">#2F3136</Color>  <!-- едва заметная граница    -->
    <Color x:Key="BorderNormal">#3A3D44</Color>  <!-- обычная граница          -->
    <Color x:Key="BorderFocus" >#FF0033</Color>  <!-- фокус / активный элемент -->

    <!-- Текст -->
    <Color x:Key="TextPrimary"  >#F2F3F5</Color> <!-- основной текст           -->
    <Color x:Key="TextSecondary">#B5BAC1</Color> <!-- вторичный текст          -->
    <Color x:Key="TextMuted"    >#6D717A</Color> <!-- заглушки, метки секций   -->
    <Color x:Key="TextDisabled" >#4E5159</Color> <!-- недоступный текст        -->

    <!-- Акцент — фирменный красный -->
    <Color x:Key="Accent"      >#FF0033</Color>
    <Color x:Key="AccentDim"   >#CC0029</Color>  <!-- нажатое состояние         -->
    <Color x:Key="AccentGlow"  >#33FF0033</Color><!-- прозрачный фон акцента   -->

    <!-- Семантические -->
    <Color x:Key="Success"     >#3BA55C</Color>  <!-- просмотрено, завершено   -->
    <Color x:Key="SuccessDim"  >#2D7D46</Color>
    <Color x:Key="Warning"     >#FAA61A</Color>
    <Color x:Key="Danger"      >#ED4245</Color>

    <!-- Белый / Чёрный с прозрачностью для оверлеев -->
    <Color x:Key="Overlay10"   >#1AFFFFFF</Color>
    <Color x:Key="Overlay20"   >#33FFFFFF</Color>
    <Color x:Key="Overlay05"   >#0DFFFFFF</Color>
    <Color x:Key="Black60"     >#99000000</Color>

</ResourceDictionary>