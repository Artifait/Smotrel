<Window x:Class="Smotrel.Views.PipPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrls="clr-namespace:Smotrel.Controls"
        Title="Smotrel — Picture in Picture"
        Width="480" Height="270"
        MinWidth="280" MinHeight="160"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">

    <!--
        The Border provides a rounded, outlined frame around the player.
        ClipToBounds on the inner SmotrelPlayer handles the video clipping.
    -->
    <Border Background="Black"
            CornerRadius="8"
            BorderBrush="#44FFFFFF"
            BorderThickness="1">

        <ctrls:SmotrelPlayer
            x:Name="PipPlayer"
            PlaybackEnded="PipPlayer_PlaybackEnded"
            PreviousRequested="PipPlayer_PreviousRequested"
            NextRequested="PipPlayer_NextRequested"
            ExitModeRequested="PipPlayer_ExitModeRequested"/>

    </Border>
</Window>
